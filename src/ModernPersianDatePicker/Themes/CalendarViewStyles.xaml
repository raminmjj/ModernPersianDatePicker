<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ModernPersianDatePicker;assembly=ModernPersianDatePicker">

    <Style Selector="local|CalendarView">
        <Setter Property="Background" Value="White"/>
        <Setter Property="MinWidth" Value="280"/>
        <Setter Property="MinHeight" Value="300"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                    <Grid RowDefinitions="Auto,*,Auto">

                        <!-- Header with navigation buttons -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
                            <Button x:Name="PART_PreviousButton"
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Left"
                                    Focusable="False">
                                <PathIcon Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z"
                                          Width="16"
                                          Height="16"/>
                            </Button>

                            <TextBlock x:Name="PART_MonthYearText"
                                       Grid.Column="1"
                                       Text="Month Year"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       FlowDirection="RightToLeft"/>

                            <Button x:Name="PART_NextButton"
                                    Grid.Column="2"
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Right"
                                    Focusable="False">
                                <PathIcon Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                          Width="16"
                                          Height="16"/>
                            </Button>
                        </Grid>

                        <!-- Days grid -->
                        <Grid x:Name="PART_DaysGrid"
                              Grid.Row="1"
                              Margin="0,4"/>

                        <!-- Today button placeholder (handled in code-behind) -->
                        <Border Grid.Row="2" Margin="0,8,0,0"/>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Day header style -->
    <Style Selector="local|CalendarView TextBlock.day-header">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FF666666"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Day button style -->
    <Style Selector="local|CalendarView Button.day-button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FF333333"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Day button hover style -->
    <Style Selector="local|CalendarView Button.day-button:pointerover">
        <Setter Property="Background" Value="#FFE0E0E0"/>
    </Style>

    <!-- Selected day button style -->
    <Style Selector="local|CalendarView Button.day-button.selected">
        <Setter Property="Background" Value="#FF2196F3"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Selected day button hover style -->
    <Style Selector="local|CalendarView Button.day-button.selected:pointerover">
        <Setter Property="Background" Value="#FF1976D2"/>
    </Style>

    <!-- Today day button style -->
    <Style Selector="local|CalendarView Button.day-button.today">
        <Setter Property="BorderBrush" Value="#FF2196F3"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

</Styles>

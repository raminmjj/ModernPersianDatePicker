<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ModernPersianDatePicker;assembly=ModernPersianDatePicker">

    <!-- ModernPersianDatePicker Style -->
    <Style Selector="local|ModernPersianDatePicker">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#FFABADB3"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="MinWidth" Value="200"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Display Text -->
                        <TextBlock x:Name="PART_DisplayText"
                                   Grid.Column="0"
                                   Text="Select date..."
                                   VerticalAlignment="Center"
                                   Margin="8,0"
                                   Foreground="#FF6D6D6D"
                                   FlowDirection="RightToLeft"/>
                        
                        <!-- Toggle Button -->
                        <ToggleButton x:Name="PART_ToggleButton"
                                Grid.Column="1"
                                Width="30"
                                Height="24"
                                Margin="0,0,4,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Focusable="False"
                                ClickMode="Press">
                            <PathIcon Data="M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M16,17H18V15H16M13,17H15V15H13M10,17H12V15H10M7,17H9V15H7M16,14H18V12H16M13,14H15V12H13M10,14H12V12H10M7,14H9V12H7M16,11H18V9H16M13,11H15V9H13M10,11H12V9H10M7,11H9V9H7M19,7H5V5H19V7Z"
                                      Width="16"
                                      Height="16"/>
                        </ToggleButton>
                        
                        <!-- Popup -->
                        <Popup x:Name="PART_Popup"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               PlacementTarget="{TemplateBinding}"
                               Placement="Bottom"
                               IsOpen="False"
                               HorizontalOffset="-1">
                            <Border Background="White"
                                    BorderBrush="#FFABADB3"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    BoxShadow="0 4 8 0 #40000000"
                                    MinWidth="280">
                                <local:CalendarView x:Name="PART_CalendarView"
                                                    FlowDirection="RightToLeft"
                                                    UseEnglishNames="{TemplateBinding UseEnglishNames}"/>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <!-- Hover state -->
    <Style Selector="local|ModernPersianDatePicker:pointerover">
        <Setter Property="BorderBrush" Value="#FF5593EB"/>
    </Style>
    
    <!-- Focused state -->
    <Style Selector="local|ModernPersianDatePicker:focus">
        <Setter Property="BorderBrush" Value="#FF5593EB"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    
    <!-- Focused with popup open -->
    <Style Selector="local|ModernPersianDatePicker:focus-within">
        <Setter Property="BorderBrush" Value="#FF5593EB"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    
    <!-- Watermark style -->
    <Style Selector="local|ModernPersianDatePicker TextBlock.watermark">
        <Setter Property="Foreground" Value="#FF999999"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>

    <!-- CalendarView Style -->
    <Style Selector="local|CalendarView">
        <Setter Property="Background" Value="White"/>
        <Setter Property="MinWidth" Value="280"/>
        <Setter Property="MinHeight" Value="300"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                    <Grid RowDefinitions="Auto,*,Auto">

                        <!-- Header with navigation buttons -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
                            <Button x:Name="PART_PreviousButton"
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Left"
                                    Focusable="False">
                                <PathIcon Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z"
                                          Width="16"
                                          Height="16"/>
                            </Button>

                            <TextBlock x:Name="PART_MonthYearText"
                                       Grid.Column="1"
                                       Text="Month Year"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       FlowDirection="RightToLeft"/>

                            <Button x:Name="PART_NextButton"
                                    Grid.Column="2"
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Right"
                                    Focusable="False">
                                <PathIcon Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                          Width="16"
                                          Height="16"/>
                            </Button>
                        </Grid>

                        <!-- Days grid -->
                        <Grid x:Name="PART_DaysGrid"
                              Grid.Row="1"
                              Margin="0,4"/>

                        <!-- Today button placeholder -->
                        <Border Grid.Row="2" Margin="0,8,0,0"/>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Day header style -->
    <Style Selector="local|CalendarView TextBlock.day-header">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FF666666"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Day button style -->
    <Style Selector="local|CalendarView Button.day-button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FF333333"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Focusable" Value="True"/>
    </Style>

    <!-- Day button hover style -->
    <Style Selector="local|CalendarView Button.day-button:pointerover">
        <Setter Property="Background" Value="#FFE0E0E0"/>
    </Style>

    <!-- Selected day button style -->
    <Style Selector="local|CalendarView Button.day-button.selected">
        <Setter Property="Background" Value="#FF2196F3"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Selected day button hover style -->
    <Style Selector="local|CalendarView Button.day-button.selected:pointerover">
        <Setter Property="Background" Value="#FF1976D2"/>
    </Style>

    <!-- Today day button style -->
    <Style Selector="local|CalendarView Button.day-button.today">
        <Setter Property="BorderBrush" Value="#FF2196F3"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Day button focus style -->
    <Style Selector="local|CalendarView Button.day-button:focus">
        <Setter Property="BorderBrush" Value="#FF5593EB"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

</Styles>

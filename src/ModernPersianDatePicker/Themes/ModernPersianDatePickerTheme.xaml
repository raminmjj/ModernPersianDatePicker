<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ModernPersianDatePicker;assembly=ModernPersianDatePicker">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ModernPersianDatePicker/Themes/PersianDatePickerColors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- ModernPersianDatePicker Style -->
    <Style Selector="local|ModernPersianDatePicker">
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PersianDatePickerBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="MinWidth" Value="200"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Display Text (non-editable mode) -->
                        <TextBlock x:Name="PART_DisplayText"
                                   Grid.Column="0"
                                   Text="Select date..."
                                   VerticalAlignment="Center"
                                   Margin="8,0"
                                   Foreground="{DynamicResource PersianDatePickerTextForegroundBrush}"
                                   FlowDirection="RightToLeft"/>
                        
                        <!-- Editable TextBox -->
                        <TextBox x:Name="PART_EditableText"
                                 Grid.Column="0"
                                 Text=""
                                 VerticalAlignment="Center"
                                 Margin="4,0"
                                 Padding="8,4"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FlowDirection="RightToLeft"
                                 IsVisible="False"/>
                        
                        <!-- Toggle Button -->
                        <ToggleButton x:Name="PART_ToggleButton"
                                Grid.Column="1"
                                Width="30"
                                Height="24"
                                Margin="0,0,4,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Focusable="False"
                                ClickMode="Press">
                            <PathIcon Data="M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M16,17H18V15H16M13,17H15V15H13M10,17H12V15H10M7,17H9V15H7M16,14H18V12H16M13,14H15V12H13M10,14H12V12H10M7,14H9V12H7M16,11H18V9H16M13,11H15V9H13M10,11H12V9H10M7,11H9V9H7M19,7H5V5H19V7Z"
                                      Width="16"
                                      Height="16"/>
                        </ToggleButton>
                        
                        <!-- Popup -->
                        <Popup x:Name="PART_Popup"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               PlacementTarget="{TemplateBinding}"
                               Placement="Bottom"
                               IsOpen="False"
                               IsLightDismissEnabled="True"
                               HorizontalOffset="-1">
                            <Border Background="{DynamicResource PersianDatePickerPopupBackgroundBrush}"
                                    BorderBrush="{DynamicResource PersianDatePickerPopupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    BoxShadow="0 4 8 0 #40000000"
                                    MinWidth="280">
                                <StackPanel>
                                    <local:CalendarView x:Name="PART_CalendarView"
                                                        FlowDirection="RightToLeft"
                                                        UseEnglishNames="{TemplateBinding UseEnglishNames}"/>
                                    <local:TimePickerView x:Name="PART_TimePickerView"
                                                           IsVisible="False"
                                                           Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <!-- Hover state -->
    <Style Selector="local|ModernPersianDatePicker:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource PersianDatePickerFocusBorderBrush}"/>
    </Style>
    
    <!-- Focused state -->
    <Style Selector="local|ModernPersianDatePicker:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource PersianDatePickerFocusBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    
    <!-- Focused with popup open -->
    <Style Selector="local|ModernPersianDatePicker:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource PersianDatePickerFocusBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    
    <!-- Watermark style -->
    <Style Selector="local|ModernPersianDatePicker TextBlock.watermark">
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerWatermarkForegroundBrush}"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>

    <!-- CalendarView Style -->
    <Style Selector="local|CalendarView">
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerPopupBackgroundBrush}"/>
        <Setter Property="MinWidth" Value="280"/>
        <Setter Property="MinHeight" Value="300"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                    <Grid RowDefinitions="Auto,*,Auto">

                        <!-- Header with navigation buttons -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
                            <Button x:Name="PART_PreviousButton"
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Left"
                                    Focusable="False">
                                <PathIcon Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z"
                                          Width="16"
                                          Height="16"/>
                            </Button>

                            <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto">
                                <Button x:Name="PART_MonthButton"
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Padding="8,4"
                                        Margin="4,0"
                                        Classes="month-year-button">
                                    <TextBlock x:Name="PART_MonthText"
                                               Text="Month"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               FlowDirection="RightToLeft"/>
                                </Button>
                                
                                <Button x:Name="PART_TodayButton"
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Padding="8,4"
                                        Margin="4,0"
                                        Classes="month-year-button"
                                        ToolTip.Tip="Go to today">
                                    <StackPanel Orientation="Horizontal">
                                        <PathIcon Data="M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M16,17H18V15H16M13,17H15V15H13M10,17H12V15H10M7,17H9V15H7M16,14H18V12H16M13,14H15V12H13M10,14H12V12H10M7,14H9V12H7M16,11H18V9H16M13,11H15V9H13M10,11H12V9H10M7,11H9V9H7M19,7H5V5H19V7Z"
                                                  Width="14"
                                                  Height="14"
                                                  Margin="0,0,4,0"/>
                                        <TextBlock x:Name="PART_TodayText"
                                                   Text="Today"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   FlowDirection="RightToLeft"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="PART_YearButton"
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Padding="8,4"
                                        Margin="4,0"
                                        Classes="month-year-button">
                                    <TextBlock x:Name="PART_YearText"
                                               Text="Year"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               FlowDirection="RightToLeft"/>
                                </Button>
                            </Grid>

                            <Button x:Name="PART_NextButton"
                                    Grid.Column="2"
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Right"
                                    Focusable="False">
                                <PathIcon Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                          Width="16"
                                          Height="16"/>
                            </Button>
                        </Grid>

                        <!-- Month selection popup -->
                        <Popup x:Name="PART_MonthPopup"
                               Placement="Bottom"
                               IsOpen="False"
                               IsLightDismissEnabled="True"
                               VerticalOffset="4">
                            <Border Background="{DynamicResource PersianDatePickerPopupBackgroundBrush}"
                                    BorderBrush="{DynamicResource PersianDatePickerPopupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    BoxShadow="0 4 8 0 #40000000"
                                    Padding="8">
                                <Grid x:Name="PART_MonthGrid"
                                      ColumnDefinitions="*,*,*"
                                      MaxWidth="200"/>
                            </Border>
                        </Popup>

                        <!-- Year selection popup -->
                        <Popup x:Name="PART_YearPopup"
                               Placement="Bottom"
                               IsOpen="False"
                               IsLightDismissEnabled="True"
                               VerticalOffset="4">
                            <Border Background="{DynamicResource PersianDatePickerPopupBackgroundBrush}"
                                    BorderBrush="{DynamicResource PersianDatePickerPopupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    BoxShadow="0 4 8 0 #40000000"
                                    Padding="8">
                                <Grid x:Name="PART_YearGrid"
                                      ColumnDefinitions="*,*,*"
                                      MaxWidth="200"/>
                            </Border>
                        </Popup>

                        <!-- Days grid -->
                        <Grid x:Name="PART_DaysGrid"
                              Grid.Row="1"
                              Margin="0,4"/>

                        <!-- Today button placeholder -->
                        <Border Grid.Row="2" Margin="0,8,0,0"/>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Day header style -->
    <Style Selector="local|CalendarView TextBlock.day-header">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerHeaderForegroundBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Day button style -->
    <Style Selector="local|CalendarView Button.day-button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerDayForegroundBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Focusable" Value="True"/>
    </Style>

    <!-- Day button hover style -->
    <Style Selector="local|CalendarView Button.day-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerDayHoverBackgroundBrush}"/>
    </Style>

    <!-- Selected day button style -->
    <Style Selector="local|CalendarView Button.day-button.selected">
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerAccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerSelectedForegroundBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Selected day button hover style -->
    <Style Selector="local|CalendarView Button.day-button.selected:pointerover">
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerAccentHoverBrush}"/>
    </Style>

    <!-- Today day button style -->
    <Style Selector="local|CalendarView Button.day-button.today">
        <Setter Property="BorderBrush" Value="{DynamicResource PersianDatePickerAccentBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Month/Year button style -->
    <Style Selector="local|CalendarView Button.month-year-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <Style Selector="local|CalendarView Button.month-year-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerMonthYearHoverBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- Day button focus style -->
    <Style Selector="local|CalendarView Button.day-button:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource PersianDatePickerFocusBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerDayFocusBackgroundBrush}"/>
    </Style>

    <!-- Focused and selected day button style -->
    <Style Selector="local|CalendarView Button.day-button.selected:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource PersianDatePickerSelectedFocusBorderBrush}"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="Background" Value="{DynamicResource PersianDatePickerSelectedFocusBackgroundBrush}"/>
    </Style>

    <!-- Holiday day button style.
         Ordered AFTER .selected/.selected:focus so a holiday keeps its red foreground
         even when selected/focused (holiday wins per requirement). -->
    <Style Selector="local|CalendarView Button.day-button.holiday">
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerHolidayForegroundBrush}"/>
    </Style>
    <Style Selector="local|CalendarView Button.day-button.holiday.selected">
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerHolidayForegroundBrush}"/>
    </Style>
    <Style Selector="local|CalendarView Button.day-button.holiday.selected:focus">
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerHolidayForegroundBrush}"/>
    </Style>
    <Style Selector="local|CalendarView Button.day-button.holiday:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource PersianDatePickerHolidayForegroundBrush}"/>
    </Style>

    <!-- TimePickerView style -->
    <Style Selector="local|TimePickerView">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <NumericUpDown x:Name="PART_HourSpinner"
                                   Minimum="0" Maximum="23"
                                   Width="60" FormatString="D2"
                                   Increment="1"/>
                    <TextBlock Text=":"
                               VerticalAlignment="Center"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource PersianDatePickerDayForegroundBrush}"/>
                    <NumericUpDown x:Name="PART_MinuteSpinner"
                                   Minimum="0" Maximum="59"
                                   Width="60" FormatString="D2"
                                   Increment="1"/>
                    <TextBlock Text=":"
                               VerticalAlignment="Center"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource PersianDatePickerDayForegroundBrush}"/>
                    <NumericUpDown x:Name="PART_SecondSpinner"
                                   Minimum="0" Maximum="59"
                                   Width="60" FormatString="D2"
                                   Increment="1"/>
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </Style>

</Styles>

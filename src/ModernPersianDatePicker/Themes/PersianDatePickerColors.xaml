<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme brushes (default) -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!-- Main control -->
            <SolidColorBrush x:Key="PersianDatePickerBackgroundBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="PersianDatePickerBorderBrush" Color="#FFABADB3"/>
            <SolidColorBrush x:Key="PersianDatePickerTextForegroundBrush" Color="#FF6D6D6D"/>
            <SolidColorBrush x:Key="PersianDatePickerWatermarkForegroundBrush" Color="#FF999999"/>

            <!-- Accent colors -->
            <SolidColorBrush x:Key="PersianDatePickerAccentBrush" Color="#FF2196F3"/>
            <SolidColorBrush x:Key="PersianDatePickerAccentHoverBrush" Color="#FF1976D2"/>
            <SolidColorBrush x:Key="PersianDatePickerFocusBorderBrush" Color="#FF5593EB"/>

            <!-- Popup -->
            <SolidColorBrush x:Key="PersianDatePickerPopupBackgroundBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="PersianDatePickerPopupBorderBrush" Color="#FFABADB3"/>

            <!-- Calendar internals -->
            <SolidColorBrush x:Key="PersianDatePickerHeaderForegroundBrush" Color="#FF666666"/>
            <SolidColorBrush x:Key="PersianDatePickerDayForegroundBrush" Color="#FF333333"/>
            <SolidColorBrush x:Key="PersianDatePickerDayHoverBackgroundBrush" Color="#FFE0E0E0"/>
            <SolidColorBrush x:Key="PersianDatePickerSelectedForegroundBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="PersianDatePickerMonthYearHoverBackgroundBrush" Color="#FFE0E0E0"/>
            <SolidColorBrush x:Key="PersianDatePickerDayFocusBackgroundBrush" Color="#FFE0E0E0"/>
            <SolidColorBrush x:Key="PersianDatePickerSelectedFocusBorderBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="PersianDatePickerSelectedFocusBackgroundBrush" Color="#FF1976D2"/>
        </ResourceDictionary>

        <!-- Dark theme brushes -->
        <ResourceDictionary x:Key="Dark">
            <!-- Main control -->
            <SolidColorBrush x:Key="PersianDatePickerBackgroundBrush" Color="#FF2D2D2D"/>
            <SolidColorBrush x:Key="PersianDatePickerBorderBrush" Color="#FF555555"/>
            <SolidColorBrush x:Key="PersianDatePickerTextForegroundBrush" Color="#FFCCCCCC"/>
            <SolidColorBrush x:Key="PersianDatePickerWatermarkForegroundBrush" Color="#FF888888"/>

            <!-- Accent colors (lighter shades for dark backgrounds) -->
            <SolidColorBrush x:Key="PersianDatePickerAccentBrush" Color="#FF64B5F6"/>
            <SolidColorBrush x:Key="PersianDatePickerAccentHoverBrush" Color="#FF2196F3"/>
            <SolidColorBrush x:Key="PersianDatePickerFocusBorderBrush" Color="#FF64B5F6"/>

            <!-- Popup -->
            <SolidColorBrush x:Key="PersianDatePickerPopupBackgroundBrush" Color="#FF2D2D2D"/>
            <SolidColorBrush x:Key="PersianDatePickerPopupBorderBrush" Color="#FF555555"/>

            <!-- Calendar internals -->
            <SolidColorBrush x:Key="PersianDatePickerHeaderForegroundBrush" Color="#FFAAAAAA"/>
            <SolidColorBrush x:Key="PersianDatePickerDayForegroundBrush" Color="#FFDDDDDD"/>
            <SolidColorBrush x:Key="PersianDatePickerDayHoverBackgroundBrush" Color="#FF404040"/>
            <SolidColorBrush x:Key="PersianDatePickerSelectedForegroundBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="PersianDatePickerMonthYearHoverBackgroundBrush" Color="#FF404040"/>
            <SolidColorBrush x:Key="PersianDatePickerDayFocusBackgroundBrush" Color="#FF404040"/>
            <SolidColorBrush x:Key="PersianDatePickerSelectedFocusBorderBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="PersianDatePickerSelectedFocusBackgroundBrush" Color="#FF2196F3"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>

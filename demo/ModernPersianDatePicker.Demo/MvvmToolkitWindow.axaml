<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:persian="using:ModernPersianDatePicker"
        xmlns:vm="using:ModernPersianDatePicker.Demo.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="750"
        x:Class="ModernPersianDatePicker.Demo.MvvmToolkitWindow"
        x:DataType="vm:MvvmToolkitWindowViewModel"
        Title="Modern Persian DatePicker Demo (CommunityToolkit.Mvvm)"
        Icon="app-icon.ico"
        Width="600" Height="1100"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MvvmToolkitWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#FFCCCCCC"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFF5F5F5"/>
                    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#FF666666"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#FF444444"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF383838"/>
                    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#FFAAAAAA"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="20">

        <!-- Calendar Type selector -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
            <TextBlock Text="Calendar:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <RadioButton GroupName="CalendarType"
                         Content="Auto" IsChecked="True"
                         Command="{Binding ChangeCalendarTypeCommand}" CommandParameter="Auto"/>
            <RadioButton GroupName="CalendarType"
                         Content="Persian"
                         Command="{Binding ChangeCalendarTypeCommand}" CommandParameter="Persian"/>
            <RadioButton GroupName="CalendarType"
                         Content="Gregorian"
                         Command="{Binding ChangeCalendarTypeCommand}" CommandParameter="Gregorian"/>
        </StackPanel>

        <!-- Title -->
        <TextBlock Grid.Row="1"
                   Text="Modern Persian DatePicker Control"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

        <!-- Basic Usage -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Basic Usage (RTL - Persian)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="BasicDatePicker"
                                                 SelectedDate="{Binding BasicDatePicker.SelectedDate}"
                                                 CalendarType="{Binding BasicDatePicker.CalendarType}"
                                                 Language="{Binding BasicDatePicker.Language}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>

                <TextBlock Text="{Binding BasicDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- English Names -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="With English Names (LTR)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="EnglishDatePicker"
                                                 SelectedDate="{Binding EnglishDatePicker.SelectedDate}"
                                                 Language="{Binding EnglishDatePicker.Language}"
                                                 DisplayFormat="{Binding EnglishDatePicker.DisplayFormat}"
                                                 CalendarType="{Binding EnglishDatePicker.CalendarType}"
                                                 FlowDirection="LeftToRight"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>

                <TextBlock Text="{Binding EnglishDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- With Custom Accent -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="With Today Button &amp; Custom Format"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="CustomDatePicker"
                                                 SelectedDate="{Binding CustomDatePicker.SelectedDate}"
                                                 DisplayFormat="{Binding CustomDatePicker.DisplayFormat}"
                                                 Language="{Binding CustomDatePicker.Language}"
                                                 CalendarType="{Binding CustomDatePicker.CalendarType}"
                                                 Watermark="Select a date..."
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>

                <TextBlock Text="{Binding CustomDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Set to Today"
                            Command="{Binding SetToTodayCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Clear Selection"
                            Command="{Binding ClearCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Show Gregorian"
                            Command="{Binding ShowGregorianCommand}"/>
                </StackPanel>

                <TextBlock Text="{Binding GregorianDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Custom Accent Theme -->
        <Border Grid.Row="5"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Custom Accent Brush (Green &amp; Purple)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <persian:ModernPersianDatePicker x:Name="GreenAccentDatePicker"
                                                     SelectedDate="{Binding GreenAccentDatePicker.SelectedDate}"
                                                     AccentBrush="{Binding GreenAccentDatePicker.AccentBrush}"
                                                     Language="{Binding GreenAccentDatePicker.Language}"
                                                     CalendarType="{Binding GreenAccentDatePicker.CalendarType}"
                                                     Watermark="Green accent..."
                                                     HorizontalAlignment="Left"
                                                     MinWidth="200"/>

                    <persian:ModernPersianDatePicker x:Name="PurpleAccentDatePicker"
                                                     SelectedDate="{Binding PurpleAccentDatePicker.SelectedDate}"
                                                     AccentBrush="{Binding PurpleAccentDatePicker.AccentBrush}"
                                                     Language="{Binding PurpleAccentDatePicker.Language}"
                                                     CalendarType="{Binding PurpleAccentDatePicker.CalendarType}"
                                                     Watermark="Purple accent..."
                                                     HorizontalAlignment="Left"
                                                     MinWidth="200"/>
                </StackPanel>

                <TextBlock Text="{Binding AccentDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Editable Date Input -->
        <Border Grid.Row="6"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Editable Date Input (IsEditable=True)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="You can type dates directly using /, -, or . separators (e.g. 1404/03/04)."
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="EditableDatePicker"
                                                 SelectedDate="{Binding EditableDatePicker.SelectedDate}"
                                                 IsEditable="{Binding EditableDatePicker.IsEditable}"
                                                 InvalidValueAction="{Binding InvalidAction}"
                                                 Language="{Binding EditableDatePicker.Language}"
                                                 CalendarType="{Binding EditableDatePicker.CalendarType}"
                                                 Watermark="Type a date..."
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>

                <TextBlock Text="{Binding EditableDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <TextBlock Text="On Invalid Input:"
                           FontWeight="SemiBold"
                           Margin="0,12,0,8"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton x:Name="RbSetToNull"
                                 GroupName="InvalidAction"
                                 Content="Set to Null"
                                 IsChecked="True"
                                 Click="OnInvalidActionChanged"/>
                    <RadioButton x:Name="RbSetToToday"
                                 GroupName="InvalidAction"
                                 Content="Set to Today"
                                 Click="OnInvalidActionChanged"/>
                    <RadioButton x:Name="RbKeep"
                                 GroupName="InvalidAction"
                                 Content="Keep"
                                 Click="OnInvalidActionChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Holidays & Theme -->
        <Border Grid.Row="7"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Holidays &amp; Theme Mode"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="Theme:" VerticalAlignment="Center"/>
                    <RadioButton GroupName="ThemeMode"
                                 Content="System" IsChecked="True"
                                 Command="{Binding ThemeCommand}" CommandParameter="System"/>
                    <RadioButton GroupName="ThemeMode"
                                 Content="Light"
                                 Command="{Binding ThemeCommand}" CommandParameter="Light"/>
                    <RadioButton GroupName="ThemeMode"
                                 Content="Dark"
                                 Command="{Binding ThemeCommand}" CommandParameter="Dark"/>
                </StackPanel>

                <TextBlock Text="Per-Instance Theme (follows OS or forced):"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <persian:ModernPersianDatePicker x:Name="ThemedDatePicker"
                                                 SelectedDate="{Binding ThemedDatePicker.SelectedDate}"
                                                 Theme="{Binding ThemedDatePicker.Theme}"
                                                 Language="{Binding ThemedDatePicker.Language}"
                                                 CalendarType="{Binding ThemedDatePicker.CalendarType}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock Text="{Binding ThemedDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <TextBlock Text="Weekly Holidays (Friday + Saturday):"
                           FontWeight="SemiBold"
                           Margin="0,16,0,8"/>
                <persian:ModernPersianDatePicker x:Name="WeeklyHolidayDatePicker"
                                                 SelectedDate="{Binding WeeklyHolidayDatePicker.SelectedDate}"
                                                 Language="{Binding WeeklyHolidayDatePicker.Language}"
                                                 CalendarType="{Binding WeeklyHolidayDatePicker.CalendarType}"
                                                 WeeklyHolidays="{Binding WeeklyHolidayDatePicker.WeeklyHolidays}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock Text="{Binding WeeklyHolidayText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <TextBlock Text="Specific Date Holidays (1 &amp; 13 Farvardin):"
                           FontWeight="SemiBold"
                           Margin="0,16,0,8"/>
                <persian:ModernPersianDatePicker x:Name="SpecificDatePicker"
                                                 SelectedDate="{Binding SpecificDatePicker.SelectedDate}"
                                                 Language="{Binding SpecificDatePicker.Language}"
                                                 CalendarType="{Binding SpecificDatePicker.CalendarType}"
                                                 Holidays="{Binding SpecificDatePicker.Holidays}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock Text="{Binding SpecificHolidayText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <TextBlock Text="Custom Holiday Brush (Orange):"
                           FontWeight="SemiBold"
                           Margin="0,16,0,8"/>
                <persian:ModernPersianDatePicker x:Name="CustomHolidayBrushDatePicker"
                                                 SelectedDate="{Binding CustomHolidayBrushDatePicker.SelectedDate}"
                                                 HolidayBrush="{Binding CustomHolidayBrushDatePicker.HolidayBrush}"
                                                 Language="{Binding CustomHolidayBrushDatePicker.Language}"
                                                 CalendarType="{Binding CustomHolidayBrushDatePicker.CalendarType}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock Text="{Binding CustomHolidayBrushText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Time Picker -->
        <Border Grid.Row="8"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Time Picker (IsTimePickerEnabled=True)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Enable time selection below the calendar with Hour/Minute/Second spinners."
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="TimePickerDatePicker"
                                                 SelectedDate="{Binding TimePickerDatePicker.SelectedDate}"
                                                 IsTimePickerEnabled="{Binding TimePickerDatePicker.IsTimePickerEnabled}"
                                                 Language="{Binding TimePickerDatePicker.Language}"
                                                 CalendarType="{Binding TimePickerDatePicker.CalendarType}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="280"/>

                <TextBlock Text="{Binding TimePickerDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Date Range Picker -->
        <Border Grid.Row="9"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Date Range Picker (IsRangeMode=True)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Click once to set start date, click again to set end date."
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="RangeDatePicker"
                                                 IsRangeMode="{Binding RangeDatePicker.IsRangeMode}"
                                                 Language="{Binding RangeDatePicker.Language}"
                                                 CalendarType="{Binding RangeDatePicker.CalendarType}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="280"/>

                <TextBlock Text="{Binding RangeDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Localization -->
        <Border Grid.Row="10"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Localization (Language selector)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Switch between Farsi, English, Arabic, and Kurdish. Implement ICalendarLocalization for custom languages."
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <RadioButton GroupName="Language"
                                 Content="Farsi" IsChecked="True"
                                 Command="{Binding LocalizedLanguageCommand}" CommandParameter="Farsi"/>
                    <RadioButton GroupName="Language"
                                 Content="English"
                                 Command="{Binding LocalizedLanguageCommand}" CommandParameter="English"/>
                    <RadioButton GroupName="Language"
                                 Content="Arabic"
                                 Command="{Binding LocalizedLanguageCommand}" CommandParameter="Arabic"/>
                    <RadioButton GroupName="Language"
                                 Content="Kurdish"
                                 Command="{Binding LocalizedLanguageCommand}" CommandParameter="Kurdish"/>
                </StackPanel>

                <persian:ModernPersianDatePicker x:Name="LocalizedDatePicker"
                                                 SelectedDate="{Binding LocalizedDatePicker.SelectedDate}"
                                                 Language="{Binding LocalizedDatePicker.Language}"
                                                 CalendarType="{Binding LocalizedDatePicker.CalendarType}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="280"/>

                <TextBlock Text="{Binding LocalizedDateText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Gregorian Calendar -->
        <Border Grid.Row="11"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Gregorian Calendar (CalendarType=Gregorian)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Switches to Western calendar with LTR layout. Scroll direction reverses automatically."
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="GregorianDatePicker"
                                                 SelectedDate="{Binding GregorianDatePicker.SelectedDate}"
                                                 Language="{Binding GregorianDatePicker.Language}"
                                                 CalendarType="{Binding GregorianDatePicker.CalendarType}"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="280"/>

                <TextBlock Text="{Binding GregorianCalendarText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Information -->
        <Border Grid.Row="12"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Features:"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="• Full Persian (Jalali/Shamsi) calendar support"
                           Margin="0,2"/>
                <TextBlock Text="• RTL and LTR layout support"
                           Margin="0,2"/>
                <TextBlock Text="• Persian and English month/day names"
                           Margin="0,2"/>
                <TextBlock Text="• Convert to/from Gregorian dates"
                           Margin="0,2"/>
                <TextBlock Text="• Leap year calculation"
                           Margin="0,2"/>
                <TextBlock Text="• Custom AccentBrush &amp; Light/Dark theme support"
                           Margin="0,2"/>
                <TextBlock Text="• Per-instance ThemeMode (System/Light/Dark)"
                           Margin="0,2"/>
                <TextBlock Text="• Weekly holidays (configurable DayOfWeek list)"
                           Margin="0,2"/>
                <TextBlock Text="• Specific date holidays with custom brush override"
                           Margin="0,2"/>
                <TextBlock Text="• Editable date input with manual typing &amp; validation"
                           Margin="0,2"/>
                <TextBlock Text="• Optional time picker (Hour/Minute/Second spinners)"
                           Margin="0,2"/>
                <TextBlock Text="• Date range picker mode (click start, click end)"
                           Margin="0,2"/>
                <TextBlock Text="• Extensible localization (Farsi, English, Arabic, Kurdish + custom)"
                           Margin="0,2"/>
                <TextBlock Text="• Gregorian calendar mode with LTR layout"
                           Margin="0,2"/>
                <TextBlock Text="• CommunityToolkit.Mvvm with source-generated bindings"
                           Margin="0,2"/>
            </StackPanel>
        </Border>

    </Grid>
    </ScrollViewer>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:persian="using:ModernPersianDatePicker"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="750"
        x:Class="ModernPersianDatePicker.Demo.MainWindow"
        Title="Modern Persian DatePicker Demo"
        Icon="app-icon.ico"
        Width="600" Height="1100"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#FFCCCCCC"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFF5F5F5"/>
                    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#FF666666"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#FF444444"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF383838"/>
                    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#FFAAAAAA"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="20">

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Modern Persian DatePicker Control"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>
        
        <!-- Basic Usage -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Basic Usage (RTL - Persian)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                
                <persian:ModernPersianDatePicker x:Name="BasicDatePicker"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                
                <TextBlock x:Name="BasicDateText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- English Names -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="With English Names (LTR)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                
                <persian:ModernPersianDatePicker x:Name="EnglishDatePicker"
                                                 UseEnglishNames="True"
                                                 FlowDirection="LeftToRight"
                                                 DisplayFormat="short"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                
                <TextBlock x:Name="EnglishDateText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- With Custom Accent -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="With Today Button &amp; Custom Format"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                
                <persian:ModernPersianDatePicker x:Name="CustomDatePicker"
                                                 DisplayFormat="long"
                                                 Watermark="Select a date..."
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                
                <TextBlock x:Name="CustomDateText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Set to Today"
                            Click="OnSetToTodayClick"
                            Margin="0,0,8,0"/>
                    <Button Content="Clear Selection"
                            Click="OnClearClick"
                            Margin="0,0,8,0"/>
                    <Button Content="Show Gregorian"
                            Click="OnShowGregorianClick"/>
                </StackPanel>
                
                <TextBlock x:Name="GregorianDateText"
                           Text="Gregorian: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- Custom Accent Theme -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Custom Accent Brush (Green &amp; Purple)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <persian:ModernPersianDatePicker x:Name="GreenAccentDatePicker"
                                                     AccentBrush="#FF4CAF50"
                                                     Watermark="Green accent..."
                                                     HorizontalAlignment="Left"
                                                     MinWidth="200"/>
                    
                    <persian:ModernPersianDatePicker x:Name="PurpleAccentDatePicker"
                                                     AccentBrush="#FF9C27B0"
                                                     Watermark="Purple accent..."
                                                     HorizontalAlignment="Left"
                                                     MinWidth="200"/>
                </StackPanel>
                
                <TextBlock x:Name="AccentDateText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- Editable Date Input -->
        <Border Grid.Row="5"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Editable Date Input (IsEditable=True)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="You can type dates directly using /, -, or . separators (e.g. 1404/03/04)."
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="EditableDatePicker"
                                                 IsEditable="True"
                                                 Watermark="Type a date..."
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>

                <TextBlock x:Name="EditableDateText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <!-- Invalid Value Action Options -->
                <TextBlock Text="On Invalid Input:"
                           FontWeight="SemiBold"
                           Margin="0,12,0,8"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton x:Name="RbSetToNull"
                                 GroupName="InvalidAction"
                                 Content="Set to Null"
                                 IsChecked="True"
                                 Click="OnInvalidActionChanged"/>
                    <RadioButton x:Name="RbSetToToday"
                                 GroupName="InvalidAction"
                                 Content="Set to Today"
                                 Click="OnInvalidActionChanged"/>
                    <RadioButton x:Name="RbKeep"
                                 GroupName="InvalidAction"
                                 Content="Keep"
                                 Click="OnInvalidActionChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Holidays & Theme -->
        <Border Grid.Row="6"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Holidays &amp; Theme Mode"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <!-- Theme selector -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="Theme:" VerticalAlignment="Center"/>
                    <RadioButton x:Name="RbThemeSystem" GroupName="ThemeMode"
                                 Content="System" IsChecked="True"
                                 Click="OnThemeModeChanged"/>
                    <RadioButton x:Name="RbThemeLight" GroupName="ThemeMode"
                                 Content="Light"
                                 Click="OnThemeModeChanged"/>
                    <RadioButton x:Name="RbThemeDark" GroupName="ThemeMode"
                                 Content="Dark"
                                 Click="OnThemeModeChanged"/>
                </StackPanel>

                <!-- Per-instance theme demo -->
                <TextBlock Text="Per-Instance Theme (follows OS or forced):"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <persian:ModernPersianDatePicker x:Name="ThemedDatePicker"
                                                 Theme="System"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock x:Name="ThemedDateText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <!-- Weekly holidays demo -->
                <TextBlock Text="Weekly Holidays (Friday + Saturday):"
                           FontWeight="SemiBold"
                           Margin="0,16,0,8"/>
                <persian:ModernPersianDatePicker x:Name="WeeklyHolidayDatePicker"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock x:Name="WeeklyHolidayText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <!-- Specific holidays demo -->
                <TextBlock Text="Specific Date Holidays (18 Dey &amp; 13 Farvardin):"
                           FontWeight="SemiBold"
                           Margin="0,16,0,8"/>
                <persian:ModernPersianDatePicker x:Name="SpecificHolidayDatePicker"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock x:Name="SpecificHolidayText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>

                <!-- Custom holiday brush demo -->
                <TextBlock Text="Custom Holiday Brush (Orange):"
                           FontWeight="SemiBold"
                           Margin="0,16,0,8"/>
                <persian:ModernPersianDatePicker x:Name="CustomHolidayBrushDatePicker"
                                                 HolidayBrush="#FFFF8800"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="250"/>
                <TextBlock x:Name="CustomHolidayBrushText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Time Picker -->
        <Border Grid.Row="7"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Time Picker (IsTimePickerEnabled=True)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Enable time selection below the calendar with Hour/Minute/Second spinners."
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,12"/>

                <persian:ModernPersianDatePicker x:Name="TimePickerDatePicker"
                                                 IsTimePickerEnabled="True"
                                                 HorizontalAlignment="Left"
                                                 MinWidth="280"/>

                <TextBlock x:Name="TimePickerDateText"
                           Text="Selected: "
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- Information -->
        <Border Grid.Row="8"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Features:"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="• Full Persian (Jalali/Shamsi) calendar support"
                           Margin="0,2"/>
                <TextBlock Text="• RTL and LTR layout support"
                           Margin="0,2"/>
                <TextBlock Text="• Persian and English month/day names"
                           Margin="0,2"/>
                <TextBlock Text="• Convert to/from Gregorian dates"
                           Margin="0,2"/>
                <TextBlock Text="• Leap year calculation"
                           Margin="0,2"/>
                <TextBlock Text="• Custom AccentBrush &amp; Light/Dark theme support"
                           Margin="0,2"/>
                <TextBlock Text="• Per-instance ThemeMode (System/Light/Dark)"
                           Margin="0,2"/>
                <TextBlock Text="• Weekly holidays (configurable DayOfWeek list)"
                           Margin="0,2"/>
                <TextBlock Text="• Specific date holidays with custom brush override"
                           Margin="0,2"/>
                <TextBlock Text="• Editable date input with manual typing &amp; validation"
                           Margin="0,2"/>
                <TextBlock Text="• Optional time picker (Hour/Minute/Second spinners)"
                           Margin="0,2"/>
            </StackPanel>
        </Border>
        
    </Grid>
    </ScrollViewer>
</Window>
